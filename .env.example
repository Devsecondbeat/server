# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Supabase API (Auth, etc.)
SUPABASE_URL=https://your-project-ref.supabase.co

# Database — recommended: copy "Transaction pooler" URI from Supabase Dashboard → Connect
# Format: postgresql://postgres.<project-ref>:[PASSWORD]@aws-1-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# Optional: discrete DB vars instead of DATABASE_URL (used when DATABASE_URL is unset)
# SUPABASE_DB_HOST=aws-1-ap-south-1.pooler.supabase.com
# SUPABASE_DB_PORT=6543
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres.your-project-ref
# SUPABASE_DB_PASSWORD=your_supabase_db_password
# SUPABASE_DB_SSL_MODE=require
# SUPABASE_DB_USE_POOLER=true

# Self-Hosted PostgreSQL (fallback) — set DB_FALLBACK_ENABLED=false for Supabase-only MVP
DBHOST=your_db_host
DBPORT=5432
DBUSERNAME=your_db_username
DATABASENAME=your_database_name
DBPASSWORD=your_db_password
DB_SSL_MODE=disable

DB_PREFERRED_SOURCE=supabase
DB_FALLBACK_ENABLED=false
DB_HEALTH_CHECK_INTERVAL=30000
DB_CONNECTION_TIMEOUT=5000
DB_MAX_RETRIES=3

# Supabase Auth
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ACTIVATION_REDIRECT_URL=http://localhost:3000/activate
SUPABASE_PASSWORD_RESET_REDIRECT_URL=http://localhost:3000/reset-password

# Cloudflare Images
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_IMAGES_HASH=your_cloudflare_images_hash

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=support@secondbeat.in

LOG_LEVEL=info
JSON_BODY_LIMIT=100kb
AUTH_RATE_LIMIT_MAX=20
