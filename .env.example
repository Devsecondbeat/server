# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Supabase Database Configuration
# Get these values from your Supabase project settings > Database > Connection string
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_DB_HOST=db.your-project-id.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your_supabase_db_password
SUPABASE_DB_SSL_MODE=require

# Self-Hosted PostgreSQL Database Configuration (Fallback)
DBHOST=your_db_host
DBPORT=5432
DBUSERNAME=your_db_username
DATABASENAME=your_database_name
DBPASSWORD=your_db_password
CERTPATH=path/to/your/certificate.pem

# Database Connection Manager Configuration
# Preferred database source: 'supabase' or 'postgresql' (default: 'supabase')
DB_PREFERRED_SOURCE=supabase
# Enable automatic fallback to alternative database (default: true)
DB_FALLBACK_ENABLED=true
# Health check interval in milliseconds (default: 30000 = 30 seconds)
DB_HEALTH_CHECK_INTERVAL=30000
# Connection timeout in milliseconds (default: 5000 = 5 seconds)
DB_CONNECTION_TIMEOUT=5000
# Maximum connection retry attempts (default: 3)
DB_MAX_RETRIES=3

# Supabase Auth Configuration
SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-side only — used to generate activation/reset links for SendGrid emails
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ACTIVATION_REDIRECT_URL=http://localhost:3000/activate
SUPABASE_PASSWORD_RESET_REDIRECT_URL=http://localhost:3000/reset-password

# Cloudflare Images Configuration
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_IMAGES_HASH=your_cloudflare_images_hash

# SendGrid Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=support@secondbeat.in

# Logging Configuration
LOG_LEVEL=info
