# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Optional: single URL for migrations (npm run db:migrate)
# DATABASE_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres

# Supabase Database — direct connection (local dev)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_DB_HOST=db.your-project-id.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your_supabase_db_password
SUPABASE_DB_SSL_MODE=require
SUPABASE_DB_USE_POOLER=false

# Supabase Database — pooler (uncomment and set when using connection pooling)
# SUPABASE_DB_HOST=aws-0-us-east-1.pooler.supabase.com
# SUPABASE_DB_PORT=6543
# SUPABASE_DB_USE_POOLER=true
# SUPABASE_DB_USER is optional; when USE_POOLER=true the app sets postgres.<project-ref> from SUPABASE_URL

# Self-Hosted PostgreSQL Database Configuration (Fallback)
# For MVP-only Supabase: set DB_FALLBACK_ENABLED=false
DBHOST=your_db_host
DBPORT=5432
DBUSERNAME=your_db_username
DATABASENAME=your_database_name
DBPASSWORD=your_db_password
# Only set CERTPATH if the file exists (self-hosted CA). Leave unset for Supabase hosted DB.
# CERTPATH=/path/to/ca.pem
DB_SSL_MODE=disable

# Database Connection Manager Configuration
DB_PREFERRED_SOURCE=supabase
DB_FALLBACK_ENABLED=true
DB_HEALTH_CHECK_INTERVAL=30000
DB_CONNECTION_TIMEOUT=5000
DB_MAX_RETRIES=3

# Supabase Auth Configuration
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ACTIVATION_REDIRECT_URL=http://localhost:3000/activate
SUPABASE_PASSWORD_RESET_REDIRECT_URL=http://localhost:3000/reset-password

# Cloudflare Images Configuration
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_IMAGES_HASH=your_cloudflare_images_hash

# SendGrid Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=support@secondbeat.in

# Logging Configuration
LOG_LEVEL=info

# Request Configuration
JSON_BODY_LIMIT=100kb
AUTH_RATE_LIMIT_MAX=20
