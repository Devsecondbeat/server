# Staging deploy — copy to .env.staging (gitignored) or merge into .env
# Used by: npm run deploy:staging

# DigitalOcean (create at https://cloud.digitalocean.com/account/api/tokens)
DIGITALOCEAN_ACCESS_TOKEN=your_do_api_token

# Staging web client origin (no trailing slash)
CORS_ORIGIN=https://your-staging-client.example.com

NODE_ENV=production
PORT=3000

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

SUPABASE_ACTIVATION_REDIRECT_URL=https://your-staging-client.example.com/activate
SUPABASE_PASSWORD_RESET_REDIRECT_URL=https://your-staging-client.example.com/reset-password

SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=support@secondbeat.in

CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_IMAGES_HASH=your_cloudflare_images_hash

DB_FALLBACK_ENABLED=false
DB_PREFERRED_SOURCE=supabase
LOG_LEVEL=info
