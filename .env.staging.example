# Staging deploy — copy to .env.staging (gitignored) or merge into .env
# Used by: npm run deploy:staging
#
# Live Cloudflare Images test (npm run test:cloudflare:staging):
# RUN_CLOUDFLARE_INTEGRATION=1 is set by that script; uses CLOUDFLARE_* below.
#
# Live API integration (npm run test:api:integration) — all endpoints vs API_BASE_URL:
# API_BASE_URL=https://secondbeat-server-nywxc.ondigitalocean.app
#
# Live API E2E (npm run test:api:e2e) — your activated staging user:
# API_TEST_EMAIL=you@example.com
# API_TEST_PASSWORD=your-password
# API_BASE_URL=https://secondbeat-server-nywxc.ondigitalocean.app

# DigitalOcean (create at https://cloud.digitalocean.com/account/api/tokens)
DIGITALOCEAN_ACCESS_TOKEN=your_do_api_token

# Staging web client origin (no trailing slash)
CORS_ORIGIN=https://your-staging-client.example.com

NODE_ENV=production
PORT=3000

SUPABASE_URL=https://your-project-ref.supabase.co
# Copy FULL keys from Supabase Dashboard > Connect (not truncated previews)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_full_key_here
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_full_secret_key_here
# Legacy JWT keys also work:
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# Must also be listed in Supabase Dashboard → Authentication → URL Configuration → Redirect URLs
# Site URL should be your staging client origin (not http://localhost:3000)
SUPABASE_ACTIVATION_REDIRECT_URL=https://your-staging-client.example.com/activate
SUPABASE_PASSWORD_RESET_REDIRECT_URL=https://your-staging-client.example.com/reset-password

SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=support@secondbeat.in

CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_IMAGES_HASH=your_cloudflare_images_hash

DB_FALLBACK_ENABLED=false
DB_PREFERRED_SOURCE=supabase
LOG_LEVEL=info
