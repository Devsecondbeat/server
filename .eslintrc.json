{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": ["airbnb-base"],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "import/extensions": ["error", "always", { "js": "ignorePackages" }],
    "max-len": ["error", { "code": 120, "ignoreUrls": true }],
    "no-underscore-dangle": "off",
    "consistent-return": "warn"
  }
}

