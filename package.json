{
  "name": "server",
  "version": "1.0.0",
  "description": "server setup and API code to support secondbeat",
  "main": "server.js",
  "scripts": {
    "start": "nodemon src/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Devsecondbeat/server.git"
  },
  "keywords": [
    "Second",
    "Beat",
    "server",
    "API",
    "setup"
  ],
  "author": "Susham Yerabolu",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Devsecondbeat/server/issues"
  },
  "homepage": "https://github.com/Devsecondbeat/server#readme",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.427.0",
    "@sendgrid/mail": "^8.1.1",
    "aws-sdk": "^2.1459.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express.js": "^1.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^2.10.0",
    "node.js": "^0.0.1-security",
    "pg": "^8.11.3",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "nodemon": "^3.0.1",
    "prettier": "^3.6.2"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "type": "module"
}
