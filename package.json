{
  "name": "server",
  "version": "1.0.0",
  "description": "server setup and API code to support secondbeat",
  "main": "server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "start:prod": "NODE_ENV=production node src/server.js",
    "start:dev": "NODE_ENV=development nodemon src/server.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "validate:env": "node -e \"import('./src/config/environment.js').then(m => m.validateEnvironment())\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Devsecondbeat/server.git"
  },
  "keywords": [
    "Second",
    "Beat",
    "server",
    "API",
    "setup"
  ],
  "author": "Susham Yerabolu",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Devsecondbeat/server/issues"
  },
  "homepage": "https://github.com/Devsecondbeat/server#readme",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.427.0",
    "@aws-sdk/s3-request-presigner": "^3.832.0",
    "@sendgrid/mail": "^8.1.1",
    "aws-sdk": "^2.1459.0",
    "bcrypt": "^5.1.1",
    "bucket": "^0.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express.js": "^1.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^2.10.0",
    "node.js": "^0.0.1-security",
    "pg": "^8.11.3",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/testConnection.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "type": "module"
}
