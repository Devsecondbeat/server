{
  "name": "server",
  "version": "1.0.0",
  "description": "server setup and API code to support secondbeat",
  "main": "server.js",
  "scripts": {
    "start": "nodemon src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Devsecondbeat/server.git"
  },
  "keywords": [
    "Second",
    "Beat",
    "server",
    "API",
    "setup"
  ],
  "author": "Susham Yerabolu",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Devsecondbeat/server/issues"
  },
  "homepage": "https://github.com/Devsecondbeat/server#readme",
  "dependencies": {
    "@sendgrid/mail": "^8.1.1",
    "@supabase/supabase-js": "^2.84.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "pg": "^8.11.3",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "vitest": "^4.1.5",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "type": "module"
}
