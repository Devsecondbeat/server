{
  "name": "server",
  "version": "1.0.0",
  "description": "server setup and API code to support secondbeat",
  "main": "server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "start:prod": "node src/server.js",
    "db:migrate": "node scripts/apply-migrations.js",
    "deploy:staging": "bash scripts/deploy-do-staging.sh",
    "deploy:staging:spec": "node scripts/render-do-app-spec.mjs",
    "sync:do:supabase": "node scripts/sync-do-supabase-env.mjs",
    "postman:generate": "node scripts/generate-postman-collection.mjs",
    "signup:debug": "node --env-file=.env.staging scripts/signup-debug.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:api:local": "RUN_API_INTEGRATION=1 vitest run tests/api.local.integration.test.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "prepare": "husky || true"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Devsecondbeat/server.git"
  },
  "keywords": [
    "Second",
    "Beat",
    "server",
    "API",
    "setup"
  ],
  "author": "Susham Yerabolu",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Devsecondbeat/server/issues"
  },
  "homepage": "https://github.com/Devsecondbeat/server#readme",
  "dependencies": {
    "@sendgrid/mail": "^8.1.1",
    "@supabase/supabase-js": "^2.84.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "pg": "^8.11.3",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "nodemon": "^3.0.1",
    "prettier": "^3.6.2",
    "supertest": "^7.1.0",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "type": "module",
  "packageManager": "npm@10.9.7"
}
